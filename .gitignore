# Unreal Engine 5 .gitignore

# Compiled binaries
fal3DDemo/Binaries/

# Build artifacts
fal3DDemo/Intermediate/

# Saved data (logs, autosaves, local settings)
fal3DDemo/Saved/

# Visual Studio files
fal3DDemo/.vs/
fal3DDemo/.vsconfig
fal3DDemo/*.sln
fal3DDemo/*.suo
fal3DDemo/*.opensdf
fal3DDemo/*.sdf
fal3DDemo/*.VC.db
fal3DDemo/*.VC.opendb

# Unreal backups
fal3DDemo/Backup/

# Derived Data Cache
fal3DDemo/DerivedDataCache/

# Upgrade log
fal3DDemo/UpgradeLog.htm

# Claude session data
.claude/

# Environment secrets
.env
.env.*
!.env.example

# Stock Epic content (included in Third Person template - too large for git)
fal3DDemo/Content/StarterContent/
fal3DDemo/Content/Characters/

# Marketplace/Fab content packs (too large for git, install locally)
fal3DDemo/Content/Stylized_PBR_Nature/
fal3DDemo/Content/UtopianCity/
fal3DDemo/Liscenses.rtf

# OS files
Thumbs.db
.DS_Store
desktop.ini
